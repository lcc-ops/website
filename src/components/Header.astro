---
import { languages, t, type Locale } from '~/i18n/ui';
import { getLocaleFromUrl, localizePath } from '~/i18n/utils';
import { SITE } from '~/site.config';

const locale: Locale = getLocaleFromUrl(Astro.url);
const path = Astro.url.pathname.replace(new RegExp(`^/(${Object.keys(languages).join('|')})(?=/|$)`), '') || '/';

const nav = [
  { href: localizePath('/', locale), key: 'nav.home' as const },
  { href: localizePath('/content', locale), key: 'nav.content' as const },
  { href: localizePath('/tools', locale), key: 'nav.tools' as const },
  { href: localizePath('/resources', locale), key: 'nav.resources' as const },
  { href: localizePath('/about', locale), key: 'nav.about' as const },
];

const otherLocale: Locale = locale === 'en' ? 'zh' : 'en';
---
<header class="sticky top-0 z-40 backdrop-blur-md" style="background:color-mix(in oklch, var(--color-bg) 85%, transparent); border-bottom: 1px solid var(--color-border);">
  <div class="container-page flex h-14 items-center justify-between">
    <a href={localizePath('/', locale)} class="flex items-center gap-2 font-semibold">
      <span aria-hidden="true">⚡</span>
      <span>{t(locale, 'site.title')}</span>
    </a>

    <nav aria-label="Primary" class="hidden gap-6 md:flex">
      {nav.map(({ href, key }) => (
        <a
          href={href}
          class="text-sm transition-colors hover:text-[var(--color-accent)]"
          aria-current={Astro.url.pathname.startsWith(href) && href !== localizePath('/', locale) ? 'page' : undefined}
        >
          {t(locale, key)}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={localizePath(path, otherLocale)}
        hreflang={otherLocale}
        aria-label={`Switch to ${languages[otherLocale]}`}
        class="text-xs font-medium px-2 py-1 rounded-md transition"
        style="border:1px solid var(--color-border);"
      >
        {otherLocale.toUpperCase()}
      </a>
      <button
        id="theme-toggle"
        type="button"
        aria-label={t(locale, 'nav.theme')}
        aria-pressed="false"
        data-label-dark={t(locale, 'nav.theme.toDark')}
        data-label-light={t(locale, 'nav.theme.toLight')}
        class="theme-toggle rounded-md p-2 transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"
        style="border:1px solid var(--color-border); --tw-ring-color: var(--color-accent);"
      >
        <span aria-hidden="true" data-theme-icon>◐</span>
      </button>
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const stored = localStorage.getItem('theme');
    if (stored === 'dark' || stored === 'light') {
      root.setAttribute('data-theme', stored);
    }
    const btn = document.getElementById('theme-toggle');
    const icon = btn?.querySelector('[data-theme-icon]');
    const isDark = () => root.getAttribute('data-theme') === 'dark';
    const syncAria = () => {
      if (!btn) return;
      const dark = isDark();
      btn.setAttribute('aria-pressed', dark ? 'true' : 'false');
      const labelFor = dark ? btn.dataset.labelLight : btn.dataset.labelDark;
      if (labelFor) btn.setAttribute('aria-label', labelFor);
      if (icon) icon.textContent = dark ? '◑' : '◐';
    };
    syncAria();
    btn?.addEventListener('click', () => {
      const next = isDark() ? 'light' : 'dark';
      root.setAttribute('data-theme', next);
      localStorage.setItem('theme', next);
      syncAria();
    });
  })();
</script>
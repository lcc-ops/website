---
import { SITE } from '~/site.config';
import { getLocaleFromUrl, localizePath } from '~/i18n/utils';
import { defaultLocale, languages, t, type Locale } from '~/i18n/ui';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
  locale?: Locale;
  alternates?: Record<Locale, string>;
}

const url = Astro.url;
const locale: Locale = Astro.props.locale ?? getLocaleFromUrl(url);
const {
  title,
  description,
  image = '/og-default.svg',
  type = 'website',
  pubDate,
  updatedDate,
  category,
  tags = [],
} = Astro.props;

const fullTitle = title === t(locale, 'site.title') ? title : `${title} · ${t(locale, 'site.title')}`;
const canonical = new URL(Astro.url.pathname, Astro.url.origin).toString();
const ogImage = new URL(image, Astro.url.origin).toString();

// Build hreflang for every locale that has a translation
const allAlternates: Record<string, string> = {
  'x-default': new URL(localizePath('/', defaultLocale), Astro.url.origin).toString(),
};
for (const loc of Object.keys(languages) as Locale[]) {
  const path = Astro.props.alternates?.[loc] ?? Astro.url.pathname;
  allAlternates[loc] = new URL(path, Astro.url.origin).toString();
}

const siteOrigin = Astro.url.origin;
const siteName = t(locale, 'site.title');
const pageUrl = canonical;

// Site-level Organization (GEO trust signal: identity, contact, social profiles)
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteOrigin}/#organization`,
  name: siteName,
  url: siteOrigin,
  logo: { '@type': 'ImageObject', url: new URL('/icon.svg', siteOrigin).toString() },
  sameAs: [
    'https://github.com/lcc-ops',
    'https://github.com/lcc-ops/website',
  ],
};

// WebSite with SearchAction (helps AI bots discover searchability)
const webSiteLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteOrigin}/#website`,
  url: siteOrigin,
  name: siteName,
  inLanguage: ['en', 'zh'],
  publisher: { '@id': `${siteOrigin}/#organization` },
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteOrigin}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

// Person: author identity (GEO E-E-A-T)
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${siteOrigin}/about/#person`,
  name: SITE.author,
  url: `${siteOrigin}/about/`,
  sameAs: [
    'https://github.com/lcc-ops',
  ],
  worksFor: { '@id': `${siteOrigin}/#organization` },
};

// Per-page entity: Article or WebPage
const pageLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': type === 'article' ? 'Article' : 'WebPage',
  '@id': pageUrl,
  headline: title,
  description,
  url: pageUrl,
  inLanguage: locale,
  isPartOf: { '@id': `${siteOrigin}/#website` },
  author: { '@id': `${siteOrigin}/about/#person` },
  publisher: { '@id': `${siteOrigin}/#organization` },
  dateModified: (updatedDate ?? pubDate ?? new Date()).toISOString(),
};
if (pubDate) pageLd.datePublished = pubDate.toISOString();
if (category) pageLd.articleSection = category;
if (tags.length) pageLd.keywords = tags.join(', ');

const jsonLd = [orgLd, webSiteLd, personLd, pageLd];
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="icon" type="image/svg+xml" href="/icon.svg" />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#0b0b0f" media="(prefers-color-scheme: dark)" />

<!-- hreflang -->
{Object.entries(allAlternates).map(([lang, href]) => (
  <link rel="alternate" hreflang={lang} href={href} />
))}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content={t(locale, 'site.title')} />
<meta property="og:locale" content={locale === 'zh' ? 'zh_CN' : 'en_US'} />
{Object.keys(languages)
  .filter((l) => l !== locale)
  .map((l) => <meta property="og:locale:alternate" content={l === 'zh' ? 'zh_CN' : 'en_US'} />)}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={title} />

<!-- RSS -->
<link rel="alternate" type="application/rss+xml" title={`${t(locale, 'site.title')} RSS`} href={new URL('/rss.xml', Astro.url.origin).toString()} />

<!-- JSON-LD: site-level Org + WebSite + Person + per-page Article/WebPage.
     Emitted as a @graph array so all entities share @id references. -->
<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@graph': jsonLd,
  })}
/>

<!-- Google AdSense -->
<script
  async
  src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2713534716131369"
  crossorigin="anonymous"
></script>

<!-- Cloudflare Web Analytics (fill beacon after deploy) -->
{SITE.analytics.cfBeacon && (
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={JSON.stringify(SITE.analytics.cfBeacon)}></script>
)}

---
/**
 * Pure-static text diff tool — runs entirely in the browser.
 * Uses a simple LCS-based line diff so the implementation stays dependency-free.
 */
---
<div class="space-y-4">
  <div class="grid gap-4 md:grid-cols-2">
    <label class="block">
      <span class="block text-xs font-medium mb-1.5" style="color: var(--color-fg-soft);">Original</span>
      <textarea
        id="tdiff-a"
        rows="8"
        class="w-full rounded-md p-3 text-sm font-mono"
        style="border:1px solid var(--color-border); background: var(--color-bg-soft);"
        spellcheck="false"
      >The quick brown fox
jumps over the lazy dog.
A second line of text.
Nothing happens here.</textarea>
    </label>
    <label class="block">
      <span class="block text-xs font-medium mb-1.5" style="color: var(--color-fg-soft);">Modified</span>
      <textarea
        id="tdiff-b"
        rows="8"
        class="w-full rounded-md p-3 text-sm font-mono"
        style="border:1px solid var(--color-border); background: var(--color-bg-soft);"
        spellcheck="false"
      >The quick brown fox
leaps over the lazy dog.
A second line of text.
A new line of text.</textarea>
    </label>
  </div>
  <div class="flex items-center gap-3 text-xs" style="color: var(--color-fg-soft);">
    <span class="inline-flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm" style="background: oklch(85% 0.12 145);"></span>Added</span>
    <span class="inline-flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm" style="background: oklch(85% 0.12 25);"></span>Removed</span>
    <span class="inline-flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded-sm" style="background: var(--color-bg-soft); border:1px solid var(--color-border);"></span>Unchanged</span>
  </div>
  <pre
    id="tdiff-out"
    class="rounded-md p-3 text-xs font-mono whitespace-pre-wrap overflow-x-auto"
    style="background: var(--color-bg-soft); border:1px solid var(--color-border); min-height: 8rem;"
  ></pre>
</div>

<script is:inline>
  (function () {
    const a = document.getElementById('tdiff-a');
    const b = document.getElementById('tdiff-b');
    const out = document.getElementById('tdiff-out');
    if (!a || !b || !out) return;

    function lcs(xs, ys) {
      const m = xs.length, n = ys.length;
      const dp = Array.from({ length: m + 1 }, () => new Uint32Array(n + 1));
      for (let i = 0; i < m; i++) {
        for (let j = 0; j < n; j++) {
          dp[i + 1][j + 1] = xs[i] === ys[j] ? dp[i][j] + 1 : Math.max(dp[i + 1][j], dp[i][j + 1]);
        }
      }
      const result = [];
      let i = m, j = n;
      while (i > 0 && j > 0) {
        if (xs[i - 1] === ys[j - 1]) { result.push([2, xs[i - 1]]); i--; j--; }
        else if (dp[i - 1][j] >= dp[i][j - 1]) { result.push([0, xs[i - 1]]); i--; }
        else { result.push([1, ys[j - 1]]); j--; }
      }
      while (i > 0) { result.push([0, xs[i - 1]]); i--; }
      while (j > 0) { result.push([1, ys[j - 1]]); j--; }
      return result.reverse();
    }

    // 0 = removed, 1 = added, 2 = same
    function render() {
      const xs = a.value.split('\n');
      const ys = b.value.split('\n');
      const diff = lcs(xs, ys);
      const escape = (s) => s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]));
      const html = diff
        .map(([op, line]) => {
          const prefix = op === 0 ? '- ' : op === 1 ? '+ ' : '  ';
          const color =
            op === 0 ? 'oklch(45% 0.16 25)' : op === 1 ? 'oklch(45% 0.16 145)' : 'var(--color-fg-soft)';
          return `<span style="color:${color};">${prefix}${escape(line || ' ')}</span>`;
        })
        .join('\n');
      out.innerHTML = html;
    }
    a.addEventListener('input', render);
    b.addEventListener('input', render);
    render();
  })();
</script>

---
import { getLocaleFromUrl, localizePath } from '~/i18n/utils';
import { type Locale } from '~/i18n/ui';

interface Crumb { label: string; href?: string }
interface Props { items: Crumb[]; locale?: Locale }
const { items } = Astro.props;
const locale: Locale = Astro.props.locale ?? getLocaleFromUrl(Astro.url);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: new URL(localizePath(c.href, locale), Astro.url.origin).toString() } : {}),
  })),
};
---
<nav aria-label="Breadcrumb" class="text-sm mb-6" style="color: var(--color-fg-soft);">
  <ol class="flex flex-wrap items-center gap-1.5">
    {items.map((c, i) => (
      <li class="flex items-center gap-1.5">
        {c.href ? <a href={localizePath(c.href, locale)} class="hover:text-[var(--color-accent)]">{c.label}</a> : <span>{c.label}</span>}
        {i < items.length - 1 && <span aria-hidden="true">/</span>}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

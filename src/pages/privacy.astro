---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { type Locale } from '~/i18n/ui';
import { getLocaleFromUrl } from '~/i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
---
<BaseLayout
  title={locale === 'en' ? 'Privacy Policy' : '隐私政策'}
  description={locale === 'en' ? 'How this site handles data.' : '本站数据使用说明。'}
>
  <article class="container-prose py-16 prose prose-neutral dark:prose-invert">
    <h1>{locale === 'en' ? 'Privacy Policy' : '隐私政策'}</h1>
    <p>{locale === 'en' ? 'Last updated: 2026-06-30' : '最后更新：2026-06-30'}</p>

    <h2>{locale === 'en' ? 'Data we collect' : '数据收集'}</h2>
    <p>{locale === 'en'
      ? 'By default this site collects nothing personally identifying. If you opt in to analytics or advertising, the relevant provider will process data per their own policy.'
      : '默认情况下本站不收集任何个人身份信息。如果启用统计或广告，相关服务方会按其自身政策处理数据。'
    }</p>

    <h2>{locale === 'en' ? 'Cookies' : 'Cookie'}</h2>
    <p>{locale === 'en'
      ? 'We use a tiny localStorage key to remember your theme and language preference. We do not use tracking cookies unless advertising is enabled.'
      : '本站仅使用 localStorage 记录主题与语言偏好。默认不使用追踪 Cookie；启用广告后另行告知。'
    }</p>

    <h2>{locale === 'en' ? 'Contact' : '联系'}</h2>
    <p>{locale === 'en' ? 'For privacy questions, see the About page for contact details.' : '隐私相关问题请通过关于页联系。'}</p>
  </article>
</BaseLayout>

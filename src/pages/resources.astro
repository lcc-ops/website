---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { type Locale, t } from '~/i18n/ui';
import { getLocaleFromUrl, localizePath } from '~/i18n/utils';
const locale: Locale = getLocaleFromUrl(Astro.url);

const isEn = locale === 'en';

const allTools = await getCollection('tools');
const toolsHere = allTools
  .filter((t) => t.id.endsWith(`/${locale}`))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const allPosts = await getCollection('content', ({ data }) => !data.draft);
const topPosts = allPosts
  .filter((p) => p.id.endsWith(`/${locale}`))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const aiPosts = allPosts
  .filter((p) => p.id.endsWith(`/${locale}`) && p.data.category === 'ai')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

// Sizes are baked in at write-time. Cloudflare Workers runtime has no fs;
// computing them at request time would require importing each file as a string,
// which inflates the worker bundle for no real benefit.
type Download = { title: string; desc: string; filename: string; tag: string; ext: string; size: string };
const downloads: Download[] = [
  {
    title: 'Pricing model',
    desc: 'Per-SKU sheet. COGS, inbound, outbound, platform + payment fees, target margin. Live formulas for suggested price, break-even, net profit.',
    filename: 'pricing-template.xlsx',
    tag: 'Excel',
    ext: '.xlsx',
    size: '8.0 KB',
  },
  {
    title: 'Product scoring',
    desc: '8 weighted dimensions (growth, price band, margin, inbound, repeat, compliance, ad difficulty, returns). 0–10 each, auto-sum.',
    filename: 'product-scoring.xlsx',
    tag: 'Excel',
    ext: '.xlsx',
    size: '8.2 KB',
  },
  {
    title: 'Ads launch SOP',
    desc: 'Meta / TikTok / Google. 7 steps before spending $1. Naming convention, audience structure, kill rules. Caveats at the bottom.',
    filename: 'ads-sop.md',
    tag: 'Markdown',
    ext: '.md',
    size: '4.0 KB',
  },
  {
    title: 'Order fulfillment SOP',
    desc: 'Receive → procure → pack → ship → deliver → post-sale. Time budgets and kill rules per stage. No 3PL contract advice.',
    filename: 'order-fulfillment-sop.md',
    tag: 'Markdown',
    ext: '.md',
    size: '4.7 KB',
  },
];

const externalLinks: Array<{ label: string; href: string; tag: string; desc: string }> = isEn
  ? [
      { label: 'Shopify pricing', href: 'https://www.shopify.com/pricing', tag: 'Platform', desc: 'Official plan breakdown — Basic / Shopify / Advanced monthly fees.' },
      { label: 'Stripe pricing', href: 'https://stripe.com/pricing', tag: 'Payment', desc: 'Per-transaction rates by country and card type.' },
      { label: 'PayPal business fees', href: 'https://www.paypal.com/us/webapps/mpp/paypal-fees', tag: 'Payment', desc: 'Commercial transaction rates and cross-border surcharges.' },
      { label: '17Track', href: 'https://www.17track.net/', tag: 'Shipping', desc: 'Universal parcel tracking across 200+ carriers.' },
      { label: 'Etsy seller fees', href: 'https://www.etsy.com/seller-handbook', tag: 'Platform', desc: 'Etsy transaction, payment processing and offsite ads fees.' },
      { label: 'Amazon FBA revenue calculator', href: 'https://sellercentral.amazon.com/help/hub/reference/GFBZX3Y6K3D78G8W', tag: 'Platform', desc: 'Amazon\'s own FBA fee and referral estimator.' },
    ]
  : [
      { label: 'Shopify 定价', href: 'https://www.shopify.com/pricing', tag: '平台', desc: '官方套餐拆解 — Basic / Shopify / Advanced 月费。' },
      { label: 'Stripe 费率', href: 'https://stripe.com/pricing', tag: '收款', desc: '按国家与卡组织划分的单笔费率。' },
      { label: 'PayPal 商业费率', href: 'https://www.paypal.com/us/webapps/mpp/paypal-fees', tag: '收款', desc: '商业交易费率与跨境附加费。' },
      { label: '17Track', href: 'https://www.17track.net/', tag: '物流', desc: '200+ 承运商通用包裹追踪。' },
      { label: 'Etsy 卖家费用', href: 'https://www.etsy.com/seller-handbook', tag: '平台', desc: 'Etsy 交易费、支付处理费与站外广告扣费。' },
      { label: 'Amazon FBA 收入计算器', href: 'https://sellercentral.amazon.com/help/hub/reference/GFBZX3Y6K3D78G8W', tag: '平台', desc: '亚马逊官方的 FBA 费与推荐费估算工具。' },
    ];
---
<BaseLayout title={t(locale, 'resources.title')} description={t(locale, 'resources.subtitle')}>
  <article>
    <section class="container-page py-16 sm:py-20">
      <p class="badge mb-4">📦 {isEn ? 'Downloads + curated links' : '下载 + 精选链接'}</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight max-w-3xl">
        {t(locale, 'resources.title')}
      </h1>
      <p class="mt-4 text-lg max-w-2xl" style="color: var(--color-fg-soft);">
        {t(locale, 'resources.subtitle')}
      </p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm" style="color: var(--color-fg-soft);">
        <span class="badge">{downloads.length} {isEn ? 'downloads' : '个下载'}</span>
        <span class="badge">{toolsHere.length} {isEn ? 'calculators' : '款计算器'}</span>
        <span class="badge">{topPosts.length} {isEn ? 'top reads' : '篇精读'}</span>
        <span class="badge">{isEn ? 'No signup' : '无需注册'}</span>
      </div>
    </section>

    <section class="container-page py-10">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-2xl font-semibold">{isEn ? 'Downloads' : '可下载文件'}</h2>
        <span class="text-sm" style="color: var(--color-fg-soft);">
          {isEn ? 'No email. Click to save.' : '无需邮箱，点击直接保存。'}
        </span>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-2">
        {downloads.map((d) => (
          <article class="card p-5 flex flex-col gap-3">
            <div class="flex items-center gap-2 text-xs" style="color: var(--color-fg-soft);">
              <span class="badge">{d.tag}</span>
              {d.size && <span>{d.size}</span>}
            </div>
            <h3 class="text-base font-semibold">{d.title}</h3>
            <p class="text-sm" style="color: var(--color-fg-soft);">{d.desc}</p>
            <div class="mt-auto pt-2">
              <a
                href={`/downloads/${d.filename}`}
                download
                class="btn btn-primary"
              >
                {isEn ? `Download ${d.ext}` : `下载 ${d.ext}`} ↗
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="container-page py-10">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-2xl font-semibold">{isEn ? 'Calculators' : '站内计算器'}</h2>
        <a href={localizePath('/tools', locale)} class="text-sm hover:text-[var(--color-accent)]">{isEn ? 'All calculators' : '全部计算器'} →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {toolsHere.map((tool) => {
          const slug = tool.id.split('/')[0];
          return (
            <a
              href={localizePath(`/tools/${slug}`, locale)}
              class="card p-5 block group"
            >
              <div class="flex items-center gap-2 text-xs mb-2" style="color: var(--color-fg-soft);">
                <span class="text-xl" aria-hidden="true">{tool.data.icon}</span>
                <span class="badge">{tool.data.category}</span>
              </div>
              <h3 class="text-base font-semibold group-hover:text-[var(--color-accent)]">{tool.data.title}</h3>
              <p class="text-sm mt-1" style="color: var(--color-fg-soft);">{tool.data.description}</p>
            </a>
          );
        })}
      </div>
    </section>

    <section class="container-page py-10">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-2xl font-semibold">{isEn ? 'Top reads' : '最值得读'}</h2>
        <a href={localizePath('/content', locale)} class="text-sm hover:text-[var(--color-accent)]">{isEn ? 'All articles' : '全部文章'} →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {topPosts.map((post) => {
          const slug = post.id.split('/')[0];
          return (
            <a
              href={localizePath(`/content/${slug}`, locale)}
              class="card p-5 block group"
            >
              <div class="flex items-center gap-2 text-xs mb-2" style="color: var(--color-fg-soft);">
                <span class="badge">{post.data.category}</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {new Intl.DateTimeFormat(isEn ? 'en-US' : 'zh-CN', { year: 'numeric', month: 'short' }).format(post.data.pubDate)}
                </time>
              </div>
              <h3 class="text-base font-semibold group-hover:text-[var(--color-accent)]">{post.data.title}</h3>
              <p class="text-sm mt-1" style="color: var(--color-fg-soft);">{post.data.description}</p>
            </a>
          );
        })}
      </div>
    </section>

    <section class="container-page py-10">
      <h2 class="text-2xl font-semibold mb-6">{isEn ? 'External links worth opening' : '值得打开的外链'}</h2>
      <ul class="space-y-3">
        {externalLinks.map((link) => (
          <li class="card p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="flex-1 min-w-[260px]">
                <div class="flex items-center gap-2 mb-2">
                  <span class="badge">{link.tag}</span>
                </div>
                <a
                  href={link.href}
                  rel="noopener noreferrer"
                  target="_blank"
                  class="text-base font-semibold hover:text-[var(--color-accent)]"
                >
                  {link.label} ↗
                </a>
                <p class="text-sm mt-1" style="color: var(--color-fg-soft);">{link.desc}</p>
              </div>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section class="container-page py-10">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-2xl font-semibold">AI Lab</h2>
        <a href={localizePath('/ai', locale)} class="text-sm hover:text-[var(--color-accent)]">{isEn ? 'All posts' : '全部文章'} →</a>
      </div>
      <p class="text-sm mb-4" style="color: var(--color-fg-soft);">
        A case-study collection tracking independent AI products. Cases are sourced from the web. No hot takes, no sponsored rankings.
      </p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {aiPosts.map((post) => {
          const slug = post.id.split('/')[0];
          return (
            <a
              href={localizePath(`/content/${slug}`, locale)}
              class="card p-5 block group"
            >
              <div class="flex items-center gap-2 text-xs mb-2" style="color: var(--color-fg-soft);">
                <span class="badge">{t(locale, 'category.ai')}</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {new Intl.DateTimeFormat(isEn ? 'en-US' : 'zh-CN', { year: 'numeric', month: 'short' }).format(post.data.pubDate)}
                </time>
              </div>
              <h3 class="text-base font-semibold group-hover:text-[var(--color-accent)]">{post.data.title}</h3>
              <p class="text-sm mt-1" style="color: var(--color-fg-soft);">{post.data.description}</p>
            </a>
          );
        })}
      </div>
    </section>
  </article>
</BaseLayout>

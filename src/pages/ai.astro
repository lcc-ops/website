---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { type Locale, t } from '~/i18n/ui';
import { getLocaleFromUrl, localizePath } from '~/i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
const isEn = locale === 'en';

const allPosts = await getCollection('content', ({ data }) => !data.draft);
const aiPosts = allPosts
  .filter((p) => p.id.endsWith(`/${locale}`) && p.data.category === 'ai')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const copy = {
  en: {
    title: 'AI Lab — Real P&L From Independent AI Products',
    intro: 'A case-study collection: I track independent AI products and break down the numbers. Cold-eyed, no hot takes, no sponsored rankings. Cases are sourced from the web.',
    stats: {
      posts: `${aiPosts.length} post${aiPosts.length === 1 ? '' : 's'}`,
      tool: '1 calculator',
      signup: 'No signup',
    },
    section: {
      tool: 'Calculator',
      latest: 'Latest',
      about: 'Why this column',
    },
    aboutP1: 'I am a case-study collector, not a commentator. The math here is the same one used on the cross-border side — pricing, margins, payback — applied to AI subscription products.',
    aboutP2: 'Cases are sourced from the web. Every formula is reproducible in the calculator below. If a number is wrong, send a note to contact@kuajinglab.xyz — I read every one.',
    openTool: 'Open calculator',
    allPosts: 'All posts',
    comingSoon: 'AI articles and the calculator ship in the next batches. This page is the landing.',
  },
  zh: {
    title: 'AI 实验 — 独立 AI 产品的真实账本',
    intro: '案例集：我跟踪独立 AI 产品，拆解数字。冷静视角，不喊单、不接推广。案例来源取自网络。',
    stats: {
      posts: `${aiPosts.length} 篇文章`,
      tool: '1 个计算器',
      signup: '无需注册',
    },
    section: {
      tool: '计算器',
      latest: '最新文章',
      about: '为什么有这个专栏',
    },
    aboutP1: '我是案例集编者，不是评论员。这里的算账和跨境那侧用的是同一套——定价、利润率、回本——只是换到了 AI 订阅产品上。',
    aboutP2: '案例来源取自网络。每个公式都能在下面的计算器里复现。如果你发现哪条结论有错，发邮件到 contact@kuajinglab.xyz 告诉我——每条都会看。',
    openTool: '打开计算器',
    allPosts: '全部文章',
    comingSoon: 'AI 文章和计算器在接下来的批次发布。这个页面是入口。',
  },
};
const c = copy[locale];

const alternates: Record<Locale, string> = {
  en: '/ai',
  zh: '/zh/ai',
};
const title = c.title;
const description = c.intro;
---
<BaseLayout title={title} description={description} alternates={alternates}>
  <article>
    <section class="container-page py-16 sm:py-20">
      <p class="badge mb-4">🧪 {isEn ? 'AI Lab' : 'AI 实验'}</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight max-w-3xl">
        {title}
      </h1>
      <p class="mt-4 text-lg max-w-2xl" style="color: var(--color-fg-soft);">
        {c.intro}
      </p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm" style="color: var(--color-fg-soft);">
        <span class="badge">{c.stats.posts}</span>
        <span class="badge">{c.stats.tool}</span>
        <span class="badge">{c.stats.signup}</span>
      </div>
    </section>

    <section class="container-page py-10">
      <div class="flex items-baseline justify-between mb-6">
        <h2 class="text-2xl font-semibold">{c.section.tool}</h2>
        <a href={localizePath('/tools/ai-break-even', locale)} class="text-sm hover:text-[var(--color-accent)]">
          {c.openTool} →
        </a>
      </div>
      <a
        href={localizePath('/tools/ai-break-even', locale)}
        class="card p-5 block group"
      >
        <div class="flex items-center gap-2 text-xs mb-2" style="color: var(--color-fg-soft);">
          <span class="text-xl" aria-hidden="true">🧮</span>
          <span class="badge">pricing</span>
        </div>
        <h3 class="text-base font-semibold group-hover:text-[var(--color-accent)]">
          {isEn ? 'AI Subscription Break-Even Calculator' : 'AI 订阅产品盈利门槛计算器'} ↗
        </h3>
        <p class="text-sm mt-1" style="color: var(--color-fg-soft);">
          {isEn
            ? 'How many paid users you need before acquisition costs pay back, given a monthly price, CAC, and average lifetime.'
            : '在客单价、获客成本、平均留存月数下，多少付费用户能回本。'}
        </p>
      </a>
    </section>

    <section class="container-page py-10">
      <h2 class="text-2xl font-semibold mb-6">{c.section.latest}</h2>
      {aiPosts.length === 0 ? (
        <p class="text-sm" style="color: var(--color-fg-soft);">{c.comingSoon}</p>
      ) : (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {aiPosts.map((post) => {
            const slug = post.id.split('/')[0];
            return (
              <a
                href={localizePath(`/content/${slug}`, locale)}
                class="card p-5 block group"
              >
                <div class="flex items-center gap-2 text-xs mb-2" style="color: var(--color-fg-soft);">
                  <span class="badge">{t(locale, 'category.ai')}</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {new Intl.DateTimeFormat(isEn ? 'en-US' : 'zh-CN', { year: 'numeric', month: 'short' }).format(post.data.pubDate)}
                  </time>
                </div>
                <h3 class="text-base font-semibold group-hover:text-[var(--color-accent)]">{post.data.title}</h3>
                <p class="text-sm mt-1" style="color: var(--color-fg-soft);">{post.data.description}</p>
              </a>
            );
          })}
        </div>
      )}
      <a href={localizePath('/content', locale)} class="mt-6 inline-block text-sm hover:text-[var(--color-accent)]">
        {c.allPosts} →
      </a>
    </section>

    <section class="container-page py-10">
      <h2 class="text-2xl font-semibold mb-4">{c.section.about}</h2>
      <div class="max-w-2xl space-y-4" style="color: var(--color-fg-soft);">
        <p>{c.aboutP1}</p>
        <p>{c.aboutP2}</p>
      </div>
    </section>
  </article>
</BaseLayout>

---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { type Locale, t } from '~/i18n/ui';
import { localizePath } from '~/i18n/utils';
const locale: Locale = 'zh';

const resourcePacks = [
  {
    title: '定价与利润核算 Excel 模板',
    desc: '插公式即用：产品成本、物流、费用、退款、广告支出。含按 SKU 和渠道的净利润看板。',
    href: '#download',
    size: '128 KB · XLSX',
  },
  {
    title: 'Dropshipping 真实成本核算表',
    desc: '完整成本堆栈（$50 AliExpress dropshipping 店铺）：货品成本、物流、广告、退货、拒付。',
    href: '#download',
    size: '94 KB · XLSX',
  },
  {
    title: '拒付申诉证据模板',
    desc: '"未收到货"和"货不符"拒付申诉模板。Stripe + PayPal 双版本。',
    href: '#download',
    size: '42 KB · DOCX',
  },
];
---
<BaseLayout title={t(locale, 'resources.title')} description={t(locale, 'resources.subtitle')}>
  <article class="container-prose py-16">
    <h1 class="text-3xl font-semibold mb-3">{t(locale, 'resources.title')}</h1>
    <p class="text-lg" style="color: var(--color-fg-soft);">{t(locale, 'resources.subtitle')}</p>

    <ul class="mt-8 space-y-4">
      {resourcePacks.map((pack) => (
        <li class="card p-5">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div>
              <h2 class="font-semibold">{pack.title}</h2>
              <p class="text-sm mt-1" style="color: var(--color-fg-soft);">{pack.desc}</p>
              <p class="text-xs mt-2" style="color: var(--color-fg-soft);">{pack.size}</p>
            </div>
            <a href={pack.href} class="btn">{t(locale, 'common.download')} ↓</a>
          </div>
        </li>
      ))}
    </ul>

    <p class="mt-10 text-xs" style="color: var(--color-fg-soft);">{t(locale, 'resources.disclosure')}</p>

    <p class="mt-10 text-sm" style="color: var(--color-fg-soft);">
      <a href={localizePath('/content', locale)} class="hover:text-[var(--color-accent)]">← {t(locale, 'nav.content')}</a>
    </p>
  </article>
</BaseLayout>
---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostCard from '~/components/PostCard.astro';
import ToolCard from '~/components/ToolCard.astro';
import CategoryChip from '~/components/CategoryChip.astro';
import SeoStructuredData from '~/components/SeoStructuredData.astro';
import { SITE } from '~/site.config';
import { t, type Locale } from '~/i18n/ui';
import { getLocaleFromUrl, localizePath } from '~/i18n/utils';
import type { CollectionEntry } from 'astro:content';

const locale: Locale = getLocaleFromUrl(Astro.url);

const allPosts = await getCollection('content', ({ data }) => !data.draft);
const allTools = await getCollection('tools');

// Pick representative posts for each home surface card (AI Lab / Guides).
// Pick the latest 3 posts per category, then resolve to the current locale.
type Surface = 'ai' | 'guide';
function pickSurface(surface: Surface, count: number) {
  const cat = surface === 'ai' ? 'ai' : null;
  const filtered = allPosts
    .filter((p) => p.id.endsWith(`/${locale}`) && !p.data.draft)
    .filter((p) => (cat ? p.data.category === cat : p.data.category !== 'ai'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, count);
  return filtered;
}
const aiCardPosts = pickSurface('ai', 3);
const guidesCardPosts = pickSurface('guide', 3);

// Home-page stats. Computed from collections / config so the numbers
// stay in sync as content grows.
const uniquePosts = new Set(allPosts.map((p) => p.data.translationKey));
const calculatorCount = allTools.length;
const currencyCount = SITE.fxCurrencies.length;
const guideCount = uniquePosts.size;

function translationsByKey(items: CollectionEntry<'content'>[] | CollectionEntry<'tools'>[]) {
  const map = new Map<string, Partial<Record<Locale, CollectionEntry<'content'> | CollectionEntry<'tools'>>>>();
  for (const item of items) {
    const key = item.data.translationKey;
    const entry = item.id.match(/^([a-z]{2})\//)?.[1] as Locale | undefined;
    if (!entry) continue;
    const current = (map.get(key) ?? {}) as Partial<Record<Locale, CollectionEntry<'content'> | CollectionEntry<'tools'>>>;
    current[entry] = item;
    map.set(key, current);
  }
  return map;
}

const postsByKey = translationsByKey(allPosts);
const toolsByKey = translationsByKey(allTools);

const postsHere = allPosts
  .filter((p) => p.id.endsWith(`/${locale}`))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const toolsHere = allTools
  .filter((p) => p.id.endsWith(`/${locale}`));

function translationFor(slug: string, target: Locale) {
  return localizePath(`/content/${slug}`, target);
}
function toolTranslationFor(slug: string, target: Locale) {
  return localizePath(`/tools/${slug}`, target);
}

const featuredCategories = ['pricing', 'shipping', 'payment', 'ads', 'ops'];
const isEn = locale === 'en';

// Top-of-page FAQ block — GEO: Q&A pairs here are the most-likely-cited
// because they sit above the fold and follow the literal question forms
// users (and AI assistants) ask.
const homeFaq = isEn
  ? [
      {
        q: 'How do I calculate the right selling price for a cross-border product?',
        a: 'Start from total cost per unit (COGS + inbound + outbound + packaging), add platform fee %, payment fee %, refund reserve %, and ad spend target, then divide by (1 − target margin). The pricing calculator does this in the browser: enter your numbers, the suggested price and break-even price update live.',
      },
      {
        q: 'How much does Amazon FBA actually take from each sale?',
        a: 'For a $25 small-standard product, expect $3.86 FBA fulfillment + 15% referral ($3.75) = $7.61 before storage and aged-inventory surcharges. With storage, aged-inventory, returns processing and removal fees, FBA takes 30–40% of the sale price on slow-moving SKUs. Work backward from a target margin or you will price yourself out.',
      },
      {
        q: 'What is chargeable weight and how do I calculate it?',
        a: 'Chargeable weight is the greater of actual weight and dimensional (volumetric) weight. Dimensional weight = (L × W × H in cm) ÷ 5000 for air/express, ÷ 6000 for sea. Carriers charge whichever is higher. The CBM calculator applies all three rules and gives total CBM, total chargeable weight, and boxes needed.',
      },
      {
        q: 'How do I find the break-even ROAS for my ads?',
        a: 'Break-even ROAS = 1 / contribution margin. If contribution margin after COGS and shipping is 40%, break-even ROAS = 2.5x. Below that, you lose money on every sale even before fixed costs. The ROAS calculator also returns max CPA and max CPC at your target CTR.',
      },
      {
        q: 'Is Crossborder Cost Lab really free, and do I need to sign up?',
        a: 'Yes, free, and no signup. All calculators run in your browser; your numbers never leave the page. No email gate, no account, no tracking before the cookie banner.',
      },
    ]
  : [
      {
        q: '跨境商品的售价怎么算？',
        a: '从单件总成本（采购 + 头程 + 尾程 + 包材）出发，加上平台费率、收款费率、退款准备金、广告预算目标，再除以（1 − 目标利润率）。定价计算器在浏览器内实时算：填入数字，建议售价和盈亏平衡价自动更新。',
      },
      {
        q: 'Amazon FBA 一单到底抽多少？',
        a: '以 $25 小标件为例：FBA 履约费 $3.86 + 推荐费 15%（$3.75）= $7.61，这还不算仓储、长期库存附加费、退货处理费、移除费。慢销 SKU 全部加起来 FBA 会抽走 30–40% 售价。必须从目标利润率反推售价，否则定多少都是亏。',
      },
      {
        q: '什么是计费重？怎么算？',
        a: '计费重 = 实重与体积重（抛重）取大。体积重 =（长 × 宽 × 高 cm）÷ 5000（空运/快递），÷ 6000（海运）。承运商按大的那个收。CBM 计算器覆盖三种规则，同时给出总体积、总计费重和所需箱数。',
      },
      {
        q: '保本 ROAS 怎么算？',
        a: '保本 ROAS = 1 ÷ 贡献利润率。如果扣完采购和物流后贡献利润率 40%，保本 ROAS 就是 2.5 倍。低于这个值每卖一单都在亏钱，更别说固定成本。ROAS 计算器同时给出最高 CPA 和最高 CPC。',
      },
      {
        q: '跨境成本实验室真的免费吗？需要注册吗？',
        a: '免费，不需要。计算器全部在浏览器内跑，数据不会离开页面。无需邮箱、无需账号、cookie 提示之前没有任何追踪。',
      },
    ];
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: homeFaq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<BaseLayout title={SITE.title} description={SITE.description}>
  <section class="container-page py-16 sm:py-24">
    <div class="grid gap-12 lg:grid-cols-[1.1fr_1fr] lg:items-center">
      <div>
        <p class="badge mb-4">{t(locale, 'home.hero.eyebrow')}</p>
        <h1 class="text-4xl sm:text-6xl font-semibold tracking-tight max-w-4xl">
          {t(locale, 'home.hero.title')}
        </h1>
        <p class="mt-5 text-lg max-w-2xl" style="color: var(--color-fg-soft);">
          {t(locale, 'home.hero.subtitle')}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={localizePath('/tools', locale)} class="btn btn-primary">{t(locale, 'home.hero.cta.calculators')} →</a>
          <a href={localizePath('/content', locale)} class="btn">{t(locale, 'home.hero.cta.guides')} →</a>
        </div>
        <dl class="mt-12 grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-2xl">
          <div class="card p-4">
            <dt class="text-xs uppercase tracking-wide" style="color: var(--color-fg-soft);">{t(locale, 'home.stats.calculators')}</dt>
            <dd class="mt-1 text-2xl font-semibold">{calculatorCount}</dd>
          </div>
          <div class="card p-4">
            <dt class="text-xs uppercase tracking-wide" style="color: var(--color-fg-soft);">{t(locale, 'home.stats.currencies')}</dt>
            <dd class="mt-1 text-2xl font-semibold">{currencyCount}</dd>
          </div>
          <div class="card p-4">
            <dt class="text-xs uppercase tracking-wide" style="color: var(--color-fg-soft);">{t(locale, 'home.stats.guides')}</dt>
            <dd class="mt-1 text-2xl font-semibold">{guideCount}</dd>
          </div>
          <div class="card p-4">
            <dt class="text-xs uppercase tracking-wide" style="color: var(--color-fg-soft);">{t(locale, 'home.stats.uptime')}</dt>
            <dd class="mt-1 text-2xl font-semibold">{SITE.stats.hosting}</dd>
          </div>
        </dl>
      </div>
      <aside aria-labelledby="hero-preview-label" class="card p-6 sm:p-8">
        <div class="flex items-center justify-between mb-6">
          <p id="hero-preview-label" class="text-xs uppercase tracking-wide" style="color: var(--color-fg-soft);">
            {t(locale, 'home.preview.label')}
          </p>
          <span class="inline-flex h-2 w-2 rounded-full bg-emerald-500" aria-hidden="true"></span>
        </div>
        <div class="grid gap-4 sm:grid-cols-3">
          <div class="rounded-lg p-4" style="background: var(--color-bg-soft);">
            <p class="text-xs uppercase tracking-wide" style="color: var(--color-fg-soft);">{t(locale, 'home.preview.price')}</p>
            <p class="mt-2 text-2xl font-semibold tabular-nums">$24.85</p>
            <p class="mt-1 text-xs" style="color: var(--color-fg-soft);">$8 cost · 30% margin</p>
          </div>
          <div class="rounded-lg p-4" style="background: var(--color-bg-soft);">
            <p class="text-xs uppercase tracking-wide" style="color: var(--color-fg-soft);">{t(locale, 'home.preview.cbm')}</p>
            <p class="mt-2 text-2xl font-semibold tabular-nums">80.0 kg</p>
            <p class="mt-1 text-xs" style="color: var(--color-fg-soft);">Air · volumetric</p>
          </div>
          <div class="rounded-lg p-4" style="background: var(--color-bg-soft);">
            <p class="text-xs uppercase tracking-wide" style="color: var(--color-fg-soft);">{t(locale, 'home.preview.breakEven')}</p>
            <p class="mt-2 text-2xl font-semibold tabular-nums">1.85x</p>
            <p class="mt-1 text-xs" style="color: var(--color-fg-soft);">$45 AOV · 25%</p>
          </div>
        </div>
        <div class="mt-6 pt-6 border-t flex items-center justify-between" style="border-color: var(--color-border);">
          <p class="text-sm" style="color: var(--color-fg-soft);">
            {locale === 'en'
              ? 'Numbers update live as you type — try the calculators below.'
              : '输入即算——直接打开下方任一计算器体验。'}
          </p>
          <a href={localizePath('/tools', locale)} class="text-sm font-medium hover:text-[var(--color-accent)]">
            {t(locale, 'home.hero.cta.calculators')} →
          </a>
        </div>
      </aside>
    </div>
  </section>

  <section class="container-page py-10" aria-labelledby="sections-heading">
    <p class="badge mb-3">{t(locale, 'home.sections.eyebrow')}</p>
    <h2 id="sections-heading" class="text-2xl sm:text-3xl font-semibold mb-2 max-w-3xl">
      {t(locale, 'home.sections.title')}
    </h2>
    <p class="mb-8 text-sm max-w-2xl" style="color: var(--color-fg-soft);">
      {t(locale, 'home.sections.subtitle')}
    </p>
    <div class="grid gap-5 md:grid-cols-3">
      <!-- Tools surface -->
      <div class="card p-6 flex flex-col">
        <p class="text-xs uppercase tracking-wide mb-2" style="color: var(--color-fg-soft);">{isEn ? 'Surface 01' : '板块 01'}</p>
        <h3 class="text-xl font-semibold mb-2">{t(locale, 'home.section.tools.title')}</h3>
        <p class="text-sm" style="color: var(--color-fg-soft);">{t(locale, 'home.section.tools.body')}</p>
        <ul class="mt-4 space-y-2 text-sm flex-1">
          {toolsHere.slice(0, 3).map((tool) => {
            const key = tool.data.translationKey;
            const other: Locale = 'zh';
            const translationLink = toolsByKey.get(key)?.[other]
              ? toolTranslationFor(key, other)
              : undefined;
            return (
              <li class="flex items-baseline gap-2">
                <span aria-hidden="true" style="color: var(--color-accent);">→</span>
                <a
                  href={localizePath(`/tools/${key}`, locale)}
                  class="hover:text-[var(--color-accent)] underline-offset-4 hover:underline"
                >
                  {tool.data.title}
                </a>
                {translationLink && <span class="text-xs" style="color: var(--color-fg-soft);">·</span>}
              </li>
            );
          })}
        </ul>
        <a
          href={localizePath('/tools', locale)}
          class="mt-5 inline-flex items-center gap-1 text-sm font-medium hover:text-[var(--color-accent)]"
        >
          {t(locale, 'home.section.tools.link')} →
        </a>
      </div>

      <!-- AI Lab surface -->
      <div class="card p-6 flex flex-col">
        <p class="text-xs uppercase tracking-wide mb-2" style="color: var(--color-fg-soft);">{isEn ? 'Surface 02' : '板块 02'}</p>
        <h3 class="text-xl font-semibold mb-2">{t(locale, 'home.section.ai.title')}</h3>
        <p class="text-sm" style="color: var(--color-fg-soft);">{t(locale, 'home.section.ai.body')}</p>
        <ul class="mt-4 space-y-2 text-sm flex-1">
          {aiCardPosts.map((post) => (
            <li class="flex items-baseline gap-2">
              <span aria-hidden="true" style="color: var(--color-accent);">→</span>
              <a
                href={localizePath(`/content/${post.id.split('/')[0]}`, locale)}
                class="hover:text-[var(--color-accent)] underline-offset-4 hover:underline line-clamp-1"
                title={post.data.title}
              >
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
        <a
          href={localizePath('/ai', locale)}
          class="mt-5 inline-flex items-center gap-1 text-sm font-medium hover:text-[var(--color-accent)]"
        >
          {t(locale, 'home.section.ai.link')} →
        </a>
      </div>

      <!-- Guides surface -->
      <div class="card p-6 flex flex-col">
        <p class="text-xs uppercase tracking-wide mb-2" style="color: var(--color-fg-soft);">{isEn ? 'Surface 03' : '板块 03'}</p>
        <h3 class="text-xl font-semibold mb-2">{t(locale, 'home.section.guides.title')}</h3>
        <p class="text-sm" style="color: var(--color-fg-soft);">{t(locale, 'home.section.guides.body')}</p>
        <ul class="mt-4 space-y-2 text-sm flex-1">
          {guidesCardPosts.map((post) => (
            <li class="flex items-baseline gap-2">
              <span aria-hidden="true" style="color: var(--color-accent);">→</span>
              <a
                href={localizePath(`/content/${post.id.split('/')[0]}`, locale)}
                class="hover:text-[var(--color-accent)] underline-offset-4 hover:underline line-clamp-1"
                title={post.data.title}
              >
                {post.data.title}
              </a>
            </li>
          ))}
        </ul>
        <a
          href={localizePath('/content', locale)}
          class="mt-5 inline-flex items-center gap-1 text-sm font-medium hover:text-[var(--color-accent)]"
        >
          {t(locale, 'home.section.guides.link')} →
        </a>
      </div>
    </div>
  </section>

  <section class="container-page py-10" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="text-2xl font-semibold mb-2">{isEn ? 'Frequently asked' : '常见问题'}</h2>
    <p class="mb-6 text-sm" style="color: var(--color-fg-soft);">
      {isEn
        ? 'Five short answers to the questions AI assistants and searchers ask most about cross-border pricing, FBA fees, and shipping math.'
        : '五个短答，覆盖 AI 助手与搜索用户最常问的跨境定价、FBA 费用、物流算账问题。'}
    </p>
    <div class="space-y-3">
      {homeFaq.map((f) => (
        <details class="card p-4">
          <summary class="font-medium cursor-pointer">{f.q}</summary>
          <p class="mt-2 text-sm" style="color: var(--color-fg-soft);">{f.a}</p>
        </details>
      ))}
    </div>
    <SeoStructuredData type="FAQPage" data={faqLd} />
  </section>

  <section class="container-page py-10">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-2xl font-semibold">{t(locale, 'home.section.calculators')}</h2>
      <a href={localizePath('/tools', locale)} class="text-sm hover:text-[var(--color-accent)]">{t(locale, 'blog.readMore')} →</a>
    </div>
    <p class="mb-6 text-sm" style="color: var(--color-fg-soft);">{t(locale, 'home.section.calculators.subtitle')}</p>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {toolsHere.map((tool) => {
        const key = tool.data.translationKey;
        const other: Locale = 'zh';
        const translationLink = toolsByKey.get(key)?.[other]
          ? toolTranslationFor(key, other)
          : undefined;
        return <ToolCard tool={tool} locale={locale} translationLink={translationLink} />;
      })}
    </div>
  </section>

  <section class="container-page py-10">
    <h2 class="text-2xl font-semibold mb-2">{t(locale, 'home.section.categories')}</h2>
    <p class="mb-6 text-sm" style="color: var(--color-fg-soft);">Pricing · Shipping · Payment · Ads · Ops</p>
    <div class="flex flex-wrap gap-2">
      {featuredCategories.map((cat) => (
        <CategoryChip category={cat} locale={locale} href={localizePath(`/content?category=${cat}`, locale)} />
      ))}
    </div>
  </section>

  <section class="container-page py-10">
    <div class="flex items-baseline justify-between mb-6">
      <h2 class="text-2xl font-semibold">{t(locale, 'home.section.guides')}</h2>
      <a href={localizePath('/content', locale)} class="text-sm hover:text-[var(--color-accent)]">{t(locale, 'blog.readMore')} →</a>
    </div>
    <p class="mb-6 text-sm" style="color: var(--color-fg-soft);">{t(locale, 'home.section.guides.subtitle')}</p>
    {postsHere.length === 0 ? (
      <p class="text-sm" style="color: var(--color-fg-soft);">{t(locale, 'blog.noPosts')}</p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {postsHere.map((post) => {
          const key = post.data.translationKey;
          const other: Locale = 'zh';
          const translationLink = postsByKey.get(key)?.[other]
            ? translationFor(key, other)
            : undefined;
          return <PostCard post={post} locale={locale} translationLink={translationLink} />;
        })}
      </div>
    )}
  </section>
</BaseLayout>
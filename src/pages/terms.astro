---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { type Locale } from '~/i18n/ui';
import { getLocaleFromUrl } from '~/i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
---
<BaseLayout
  title={locale === 'en' ? 'Terms of Service' : '服务条款'}
  description={locale === 'en' ? 'Terms of using this site.' : '使用本站的条款。'}
>
  <article class="container-prose py-16 prose prose-neutral dark:prose-invert">
    <h1>{locale === 'en' ? 'Terms of Service' : '服务条款'}</h1>
    <p>{locale === 'en' ? 'Last updated: 2025-12-10' : '最后更新：2025-12-10'}</p>

    <h2>{locale === 'en' ? 'Content' : '内容'}</h2>
    <p>{locale === 'en'
      ? 'All articles are provided as-is for informational purposes. The author is not liable for decisions made based on the content.'
      : '所有文章按「现状」提供，仅作信息参考。基于内容作出的决策，损失由使用者自行承担。'
    }</p>

    <h2>{locale === 'en' ? 'Tools' : '工具'}</h2>
    <p>{locale === 'en'
      ? 'Tools run entirely in your browser. The author is not responsible for the accuracy of results or any data loss during use.'
      : '工具完全在浏览器中运行，作者不对结果准确性或使用过程中的数据丢失负责。'
    }</p>

    <h2>{locale === 'en' ? 'Affiliate links' : '推广链接'}</h2>
    <p>{locale === 'en'
      ? 'Some outbound links may be affiliate links. We mark them with rel="nofollow sponsored" and only recommend resources we have used or evaluated.'
      : '部分外链可能为推广链接。我们会标注 rel="nofollow sponsored"，并只推荐已使用或评估过的资源。'
    }</p>
  </article>
</BaseLayout>

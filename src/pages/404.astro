---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { type Locale } from '~/i18n/ui';
import { getLocaleFromUrl, localizePath } from '~/i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);
---
<BaseLayout title="404" description="Page not found">
  <section class="container-page py-24 text-center">
    <p class="text-6xl font-semibold mb-2">404</p>
    <h1 class="text-2xl font-semibold mb-3">{locale === 'en' ? 'Page not found' : '页面未找到'}</h1>
    <p style="color: var(--color-fg-soft);" class="mb-6">
      {locale === 'en' ? 'The page you are looking for has moved or no longer exists.' : '你访问的页面可能已迁移或不存在。'}
    </p>
    <a href={localizePath('/', locale)} class="btn btn-primary">{locale === 'en' ? 'Back to home' : '返回首页'}</a>
  </section>
</BaseLayout>

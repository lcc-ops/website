---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import PostCard from '~/components/PostCard.astro';
import CategoryChip from '~/components/CategoryChip.astro';
import { type Locale, t, categoryLabels } from '~/i18n/ui';
import { getLocaleFromUrl, localizePath } from '~/i18n/utils';

const locale: Locale = getLocaleFromUrl(Astro.url);

const allPosts = await getCollection('content', ({ data }) => !data.draft);
const localeOf = (id: string): Locale | undefined =>
  id.split('/').pop() as Locale | undefined;
const posts = allPosts
  .filter((p) => localeOf(p.id) === locale)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const byKey = new Map<string, { en?: string; zh?: string }>();
for (const p of allPosts) {
  const loc = localeOf(p.id);
  if (!loc) continue;
  const k = p.data.translationKey;
  byKey.set(k, { ...(byKey.get(k) ?? {}), [loc]: `/content/${p.id.split('/')[0]}` });
}

const categoryParam = Astro.url.searchParams.get('category');
const activeCategory = categoryParam && categoryParam in categoryLabels[locale] ? categoryParam : undefined;

const filtered = activeCategory ? posts.filter((p) => p.data.category === activeCategory) : posts;

const featuredCategories = ['pricing', 'shipping', 'payment', 'ads', 'ops', 'guide', 'ai'];
---
<BaseLayout title={t(locale, 'nav.content')} description={t(locale, 'home.section.guides.subtitle')}>
  <section class="container-page py-16">
    <h1 class="text-3xl font-semibold mb-2">{t(locale, 'nav.content')}</h1>
    <p class="mb-6" style="color: var(--color-fg-soft);">
      {filtered.length} {locale === 'zh' ? '篇' : ''}{locale === 'en' ? (filtered.length === 1 ? ' post' : ' posts') : ''}
    </p>

    <div class="mb-8 flex flex-wrap gap-2">
      <CategoryChip category="all" locale={locale} href={localizePath('/content', locale)} active={!activeCategory} />
      {featuredCategories.map((cat) => (
        <CategoryChip category={cat} locale={locale} active={activeCategory === cat} />
      ))}
    </div>

    {filtered.length === 0 ? (
      <p style="color: var(--color-fg-soft);">{t(locale, 'blog.noPosts')}</p>
    ) : (
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {filtered.map((post) => {
          const other = locale === 'en' ? 'zh' : 'en';
          const translation = byKey.get(post.data.translationKey)?.[other];
          const translationLink = translation ? localizePath(translation, other) : undefined;
          return <PostCard post={post} locale={locale} translationLink={translationLink} />;
        })}
      </div>
    )}
  </section>
</BaseLayout>
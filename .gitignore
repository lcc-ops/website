# dependencies
node_modules/
.pnpm-store/

# build output
dist/
.astro/
.wrangler/

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# environment
.env
.env.local
.env.*.local

# editor / OS
.DS_Store
.vscode/
.idea/
Thumbs.db

# agent / harness
.claude/
.agents/

# Cloudflare Pages build debug snapshot (not source)
.cf-builds-config.html

# local notes (not tracked)
docs/NOTES.md

# local scrapers (not tracked — agent-only tooling, never committed)
scripts/scrapers/
scripts/scrapers/*

# scripts/auto runtime artifacts (sources tracked, run output never).
# state.json is structurally tracked but only its schema baseline matters —
# commit-level churn comes from running the daily batch in-place.
scripts/auto/_queue/
scripts/auto/_archive/
scripts/auto/logs/
scripts/auto/state.json.bak.*
scripts/auto/state.lock

# Python bytecode (anywhere in the repo)
__pycache__/
*.pyc
*.pyo

# pytest
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
